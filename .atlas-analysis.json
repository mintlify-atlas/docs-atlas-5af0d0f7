  "keyFeatures": [
    "Automatic instrumentation for OpenAI and Anthropic clients",
    "Hierarchical trace/span/event data model with context propagation",
    "Versioned prompt management with Jinja/Python template support",
    "Deterministic and LLM-based evaluation graders (rubric, faithfulness, tool sequence, regex, Python/TypeScript code graders)",
    "LLM cost and token tracking via LiteLLM pricing",
    "Background worker queue with configurable batching and retry",
    "Sensitive field redaction before data transmission",
    "Multi-project dashboard with real-time trace viewer, playground, and alert rules"
  ],
